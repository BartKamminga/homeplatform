{
  "manifest_version": 3,
  "name": "Beatport Vanger",
  "version": "1.1",
  "description": "Sla Beatport playlists en charts op en stuur ze naar BeatCrades",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://www.beatport.com/*",
    "https://webheaven.nl/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "action": {
    "default_title": "Beatport Vanger openen"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
