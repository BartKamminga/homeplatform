# Kopieer dit bestand naar .env en pas de waarden aan
# .env wordt NIET naar Git gepusht

DATABASE_URL=sqlite:///../db/homeplatform.sqlite
SECRET_KEY=changeme-generate-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development
UPLOAD_ROOT=./uploads

# Foutregistratie (GlitchTip op NAS)
# Vul in na aanmaken project in GlitchTip (http://192.168.30.193:8090)
SENTRY_DSN=
GLITCHTIP_SECRET_KEY=changeme-generate-random-glitchtip-key

# Productie (NAS): zet ENVIRONMENT=production
