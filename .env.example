# HomePlatform omgevingsvariabelen
# Kopieer naar .env en vul de waarden in — .env wordt NIET gepusht naar Git.

# --- Database ---
DATABASE_URL=sqlite:///./db/homeplatform.sqlite

# --- Auth (verplicht: verander SECRET_KEY in productie!) ---
SECRET_KEY=dev-secret-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# --- Omgeving ---
ENVIRONMENT=development
# ENVIRONMENT=production

# --- Uploads ---
UPLOAD_ROOT=/app/uploads

# --- Muziek ---
MUSIC_DIR=/app/music

# --- CORS (kommagescheiden; leeg = automatisch op basis van ENVIRONMENT) ---
CORS_ORIGINS=

# --- Sentry / GlitchTip (optioneel) ---
SENTRY_DSN=
SENTRY_MIN_LEVEL=warning
GLITCHTIP_SECRET_KEY=changeme-generate-random-glitchtip-key

# --- NAS (gebruikt door hpem.ps1 en de admin-UI) ---
NAS_URL=
NAS_IP=192.168.30.193
NAS_PATH=/volume1/homeplatform
