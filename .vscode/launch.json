{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "DATABASE_URL": "sqlite:///../db/homeplatform.sqlite",
        "SECRET_KEY": "dev-secret-key",
        "ENVIRONMENT": "development",
        "SENTRY_DSN": ""
      },
      "justMyCode": true
    },
    {
      "name": "Chrome (Vite)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5172/landing/",
      "webRoot": "${workspaceFolder}/frontend/sites"
    }
  ],
  "compounds": [
    {
      "name": "▶ Start Homeplatform",
      "configurations": ["FastAPI backend", "Chrome (Vite)"],
      "preLaunchTask": "Start Homeplatform",
      "stopAll": true
    }
  ]
}
