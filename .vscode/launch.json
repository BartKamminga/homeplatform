{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "DATABASE_URL": "sqlite:///./db/homeplatform.sqlite",
        "SECRET_KEY": "dev-secret-key",
        "ENVIRONMENT": "development"
      },
      "justMyCode": true
    },
    {
      "name": "Chrome (proxy)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5170/admin/login",
      "webRoot": "${workspaceFolder}/frontend"
    }
  ],
  "compounds": [
    {
      "name": "▶ Start Homeplatform",
      "configurations": ["FastAPI backend", "Chrome (proxy)"],
      "preLaunchTask": "Start Homeplatform",
      "stopAll": true
    }
  ]
}
