{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Vite",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend/sites" },
      "isBackground": true,
      "presentation": { "reveal": "silent", "panel": "dedicated", "label": "Vite" },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": { "activeOnStart": true, "beginsPattern": "VITE", "endsPattern": "Local:" }
      }
    },
    {
      "label": "Start Homeplatform",
      "dependsOn": ["Start Vite"],
      "dependsOrder": "parallel"
    }
  ]
}
