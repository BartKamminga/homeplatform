{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Admin Vite",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend/sites/admin" },
      "isBackground": true,
      "presentation": { "reveal": "silent", "panel": "dedicated", "label": "Vite Admin" },
      "problemMatcher": {
        "pattern": { "regexp": "^$" },
        "background": { "activeOnStart": true, "beginsPattern": "VITE", "endsPattern": "Local:" }
      }
    },
    {
