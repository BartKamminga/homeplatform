        "background": { "activeOnStart": true, "beginsPattern": "Proxy draait", "endsPattern": "Proxy draait" }
      }
    },
    {
      "label": "Start Homeplatform",
      "dependsOn": [
        "Start Admin Vite",
        "Start Nkhockey Vite",
        "Start Mixmusic Vite",
        "Start Landing Vite",
        "Start DontForget Vite",
        "Start Proxy"
